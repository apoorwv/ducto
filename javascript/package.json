{
  "name": "@apoorwv/ducto",
  "version": "2.0.0",
  "description": "Declarative credit calculation engine for AI SaaS platforms",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --check src/ tests/",
    "format:fix": "prettier --write src/ tests/",
    "knip": "knip",
    "prepublishOnly": "npm run build && vitest run"
  },
  "keywords": [
    "credits",
    "billing",
    "llm",
    "usage-metering",
    "pricing"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/apoorwv/ducto.git"
  },
  "bugs": {
    "url": "https://github.com/apoorwv/ducto/issues"
  },
  "homepage": "https://apoorwv.github.io/ducto/",
  "license": "MIT",
  "dependencies": {
    "decimal.js": "^10.6.0"
  },
  "peerDependencies": {
    "js-yaml": "^4.0.0",
    "pg": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "js-yaml": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "eslint": "^10.5.0",
    "js-yaml": "^4.2.0",
    "knip": "^6.18.0",
    "pg": "^8.22.0",
    "prettier": "^3.8.4",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^3.2.6"
  }
}
