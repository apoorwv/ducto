  ],
  "pricing_cases": [
    {"name": "default_model", "config": {"version": 1, "models": {"_default": "input_tokens * (0.01 / 1000) + output_tokens * (0.03 / 1000)"}}, "metrics": {"model": "gpt-4", "input_tokens": 500, "output_tokens": 200}, "expected_total": "0.0110"},
